    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
        color: #e0e0e0;
        line-height: 1.6;
        min-height: 100vh;
        padding: 20px;
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;
    }

    header {
        text-align: center;
        margin-bottom: 40px;
        padding-top: 20px;
    }

    h1 {
        font-size: 2.5em;
        font-weight: 700;
        margin-bottom: 8px;
        background: linear-gradient(135deg, #ffffff 0%, #b0b0ff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: 1em;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .day-section {
        margin-bottom: 50px;
    }

    .day-header {
        font-size: 1.3em;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #64b5f6;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid rgba(100, 181, 246, 0.3);
    }

    .location-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(100, 181, 246, 0.2);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 16px;
        transition: all 0.3s ease;
    }

    .location-card:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(100, 181, 246, 0.4);
        transform: translateY(-2px);
    }

    .location-number {
        display: inline-block;
        background: linear-gradient(135deg, #64b5f6 0%, #42a5f5 100%);
        color: #0a0e27;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9em;
        margin-bottom: 12px;
    }

    .location-name {
        font-size: 1.4em;
        font-weight: 700;
        margin-bottom: 12px;
        color: #ffffff;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
    }

    .info-block {
        display: flex;
        flex-direction: column;
    }

    .info-label {
        font-size: 0.75em;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #64b5f6;
        margin-bottom: 6px;
        font-weight: 600;
    }

    .info-value {
        color: #e0e0e0;
        font-size: 1em;
    }

    .shot-description {
        background: rgba(100, 181, 246, 0.1);
        border-left: 3px solid #64b5f6;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 16px;
        font-size: 0.95em;
        line-height: 1.5;
    }

    .map-button {
        display: inline-block;
        background: linear-gradient(135deg, #64b5f6 0%, #42a5f5 100%);
        color: #0a0e27;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9em;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-align: center;
    }

    .map-button:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 25px rgba(100, 181, 246, 0.3);
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 1.8em;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .location-card {
            padding: 16px;
        }

        body {
            padding: 16px;
        }
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 40px;
        padding: 20px;
        background: rgba(100, 181, 246, 0.1);
        border: 1px solid rgba(100, 181, 246, 0.2);
        border-radius: 12px;
        text-align: center;
    }

    .stat-item h3 {
        color: #64b5f6;
        font-size: 2em;
        margin-bottom: 4px;
    }

    .stat-item p {
        font-size: 0.8em;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    @media (max-width: 600px) {
        .stats {
            grid-template-columns: 1fr;
        }
    }
</style>
